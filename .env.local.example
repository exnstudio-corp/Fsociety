# ============================================================
# F-Society — Environment Variables Template
# EXN STUDIO
#
# USAGE:
#   1. Copy this file: cp .env.local.example .env.local
#   2. Fill in your real values below
#   3. NEVER commit .env.local to Git
#   4. Add .env.local to your .gitignore
#
# FOR NETLIFY PRODUCTION:
#   Set each variable in:
#   Netlify Dashboard → Site Settings → Environment Variables
#   Do NOT rely on this file in production — it is local only.
#
# FOR LOCAL DEVELOPMENT:
#   If you use Netlify CLI (netlify dev), this file is picked
#   up automatically and injected into your Netlify functions.
#   Install CLI: npm install -g netlify-cli
#   Run locally: netlify dev
# ============================================================


# ── SUPABASE ─────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API

# Your Supabase project URL (always ends in .supabase.co)
SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anon/public key
# Safe to use in the browser — this is the PUBLIC key
# Row Level Security (RLS) policies protect your data
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-here


# ── JSONBIN ───────────────────────────────────────────────────
# Found in: jsonbin.io → Dashboard → API Keys / Bins
# NOTE: The API key is a MASTER key — it is kept server-side only.
# F-Society proxies all JSONBin requests through:
#   /.netlify/functions/articles
# so this key never appears in browser requests.

# Your JSONBin bin ID (the alphanumeric string in your bin's URL)
JSONBIN_BIN_ID=your-bin-id-here

# Your JSONBin master API key (server-side only — never exposed to browser)
JSONBIN_API_KEY=your-jsonbin-master-key-here


# ============================================================
# QUICK REFERENCE — Where each variable is used:
#
# SUPABASE_URL        → auth.js (login, signup, session)
#                       chat.js (realtime, messages, file storage)
#                       account.js (profile, deletion)
#                       netlify/functions/env.js (injected to browser)
#
# SUPABASE_ANON_KEY   → Same as above (public key, safe for browser)
#
# JSONBIN_BIN_ID      → netlify/functions/articles.js (server-side only)
#
# JSONBIN_API_KEY     → netlify/functions/articles.js (server-side only)
#                       NEVER exposed to browser
# ============================================================


# ============================================================
# SECURITY NOTES:
#
# - SUPABASE_ANON_KEY is intentionally public — it is the
#   "anon" key. Supabase Row Level Security policies control
#   what authenticated vs anonymous users can access.
#
# - JSONBIN_API_KEY is your MASTER key. It gives full access
#   to your JSONBin account. Keep it strictly server-side.
#   F-Society's Netlify function proxy ensures it never reaches
#   the browser.
#
# - Never hardcode any of these values in your HTML or JS files.
#
# - Rotate your JSONBIN_API_KEY immediately if it is ever
#   accidentally committed to a public repository.
# ============================================================
